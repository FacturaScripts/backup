{% extends "Master/MenuBghTemplate.html.twig" %}

{% block body %}
	<div class="bg-light pt-4 pb-5">
		<div class="container pb-4">
			<div class="row">
				<div class="col">
					<ul class="nav nav-pills mb-3" role="tablist">
						<li class="nav-item" role="presentation">
							{% set btnClass = fsc.active_tab == 'download' ? 'nav-link active' : 'nav-link' %}
							<button class="{{ btnClass }}" id="download-tab" data-bs-toggle="tab" data-bs-target="#download" type="button" role="tab" aria-controls="download" aria-selected="true">
								<i class="fa-solid fa-download me-1"></i>
								{{ trans('download') }}
							</button>
						</li>
						<li class="nav-item" role="presentation">
							{% set btnClass = fsc.active_tab == 'restore' ? 'nav-link active' : 'nav-link' %}
							<button class="{{ btnClass }}" id="restore-tab" data-bs-toggle="tab" data-bs-target="#restore" type="button" role="tab" aria-controls="restore" aria-selected="false">
								<i class="fa-solid fa-upload me-1"></i>
								{{ trans('restore') }}
							</button>
						</li>
						<li class="nav-item" role="presentation">
							{% set btnClass = fsc.active_tab == 'settings' ? 'nav-link active' : 'nav-link' %}
							<button class="{{ btnClass }}" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab" aria-controls="settings" aria-selected="false">
								<i class="fa-solid fa-cog me-1"></i>
								{{ trans('settings') }}
							</button>
						</li>
					</ul>
				</div>
				<div class="col-auto">
					<h1 class="h4">
						<i class="fa-solid fa-save fa-fw"></i>
						{{ fsc.title }}
					</h1>
				</div>
			</div>
		</div>
	</div>
	<div class="container" style="margin-top: -65px;">
		<div class="row">
			<div class="col">
				<div class="tab-content">
					{% set tabClass = fsc.active_tab == 'download' ? 'tab-pane fade show active' : 'tab-pane fade' %}
					<div class="{{ tabClass }}" id="download" role="tabpanel" aria-labelledby="download-tab">
						<form action="{{ fsc.url() }}" id="f_download" method="post">
							{{ formToken() }}
							<input type="hidden" name="action">
							<input type="hidden" name="file_name">
							<div class="card shadow mb-4">
								<div class="card-body">
									<h2 class="h3">
										<i class="fa-solid fa-file-arrow-down me-2"></i>
										{{ trans('download-backup') }}
									</h2>
									<p class="card-text">{{ trans('download-backup-p') }}</p>
								</div>
								<div class="card-footer p-2">
									<button type="button" class="btn btn-secondary btn-spin-action me-2" onclick="createBackupAction('create-sql-file')">
										<i class="fa-solid fa-database me-2"></i>
										{{ trans('database') }}
									</button>
									<button type="submit" class="btn btn-secondary btn-spin-action" onclick="createBackupAction('create-zip-file')">
										<i class="fa-solid fa-box-archive me-2"></i>
										{{ trans('files') }}
									</button>
								</div>
							</div>
							<div class="card shadow mb-5">
								<div class="card-body">
									<h3 class="h4 mb-0">
										<i class="fa-solid fa-calendar-days me-2"></i>
										{{ trans('history') }}
									</h3>
								</div>
								<div class="table-responsive">
									<table class="table table-hover mb-0">
										<tbody>
											{% if fsc.backup_list is empty %}
												<tr>
													<td colspan="5" class="table-warning">
														{{ trans('no-data') }}
													</td>
												</tr>
											{% else %}
												{% for day, entries in fsc.backup_list %}
													<tr class="table-dark">
														<th colspan="5" class="py-2">
															<i class="fa-solid fa-calendar-day me-2"></i>
															{{ day[6:2] }}/{{ day[4:2] }}/{{ day[0:4] }}
														</th>
													</tr>
													<tr class="table-secondary">
														<th>{{ trans('database') }}</th>
														<th class="text-end">{{ trans('size') }}</th>
														<th>{{ trans('files') }}</th>
														<th class="text-end">{{ trans('size') }}</th>
														<th></th>
													</tr>
													{% for backup in entries %}
														<tr>
															<td>
																{% if backup.sql_file %}
																	<a href="#" onclick="downloadBackupAction('download-sql-file','{{ backup.sql_file }}')">
																		<i class="fa-solid fa-database me-1"></i>
																		{{ backup.sql_file }}
																	</a>
																{% else %}
																	-
																{% endif %}
															</td>
															<td class="text-end">
																{% if backup.sql_file %}
																	{{ bytes(backup.sql_size) }}
																{% else %}
																	-
																{% endif %}
															</td>
															<td>
																{% if backup.zip_file %}
																	<a href="#" onclick="downloadBackupAction('download-zip-file','{{ backup.zip_file }}')">
																		<i class="fa-solid fa-box-archive me-1"></i>
																		{{ backup.zip_file }}
																	</a>
																{% else %}
																	-
																{% endif %}
															</td>
															<td class="text-end">
																{% if backup.zip_file %}
																	{{ bytes(backup.zip_size) }}
																{% else %}
																	-
																{% endif %}
															</td>
															<td class="text-end">
																{% if backup.sql_file or backup.zip_file %}
																	<a href="#" onclick="deleteBackupAction('{{ backup.sql_file }}','{{ backup.zip_file }}')" title="{{ trans('delete') }}">
																		<i class="fa-solid fa-trash-alt text-danger"></i>
																	</a>
																{% endif %}
															</td>
														</tr>
													{% endfor %}
												{% endfor %}
											{% endif %}
										</tbody>
									</table>
								</div>
							</div>
						</form>
					</div>
					{% set tabClass = fsc.active_tab == 'restore' ? 'tab-pane fade show active' : 'tab-pane fade' %}
					<div class="{{ tabClass }}" id="restore" role="tabpanel" aria-labelledby="restore-tab">
						<form action="{{ fsc.url() }}" id="f_restore_db" method="post" enctype="multipart/form-data">
							{{ formToken() }}
							<input type="hidden" name="action" value="restore-backup"/>
							<input type="hidden" name="active_tab" value="restore"/>
							<div class="card shadow mb-4">
								<div class="card-body bg-warning">
									<h3 class="h5 mb-0">
										<i class="fa-solid fa-database me-2"></i>
										{{ trans('restore-backup') }}
									</h3>
								</div>
								<div class="card-body">
									<p>
										{{ trans('restore-backup-p') }}
										<span class="text-danger">{{ trans('restore-backup-warning') }}</span>
									</p>
									<div class="mb-3">
										<label for="db_file" class="form-label">{{ trans('database') }}</label>
										<input type="file" name="db_file" id="db_file" accept=".sql,.sql.gz" class="form-control" required/>
									</div>
									<p class="card-text text-muted">
										{{ trans('help-server-accepts-filesize', {'%size%': fsc.getMaxFileUpload()}) }}
									</p>
									<hr/>
									<p class="card-text">
										<i class="fa-solid fa-user-shield me-1"></i>
										<strong>{{ trans('restore-admin-access') }}</strong>
										— {{ trans('restore-admin-access-p') }}
									</p>
									<div class="mb-3">
										<div class="form-check">
											<input class="form-check-input" type="radio" name="admin_action" id="admin_action_none" value="none" checked onchange="toggleAdminFields()"/>
											<label class="form-check-label" for="admin_action_none">{{ trans('restore-admin-no-changes') }}</label>
										</div>
										<div class="form-check">
											<input class="form-check-input" type="radio" name="admin_action" id="admin_action_update" value="update" onchange="toggleAdminFields()"/>
											<label class="form-check-label" for="admin_action_update">{{ trans('restore-admin-update-password') }}</label>
										</div>
										<div class="form-check">
											<input class="form-check-input" type="radio" name="admin_action" id="admin_action_create" value="create" onchange="toggleAdminFields()"/>
											<label class="form-check-label" for="admin_action_create">{{ trans('restore-admin-create-user') }}</label>
										</div>
									</div>
									<div id="admin_update_fields" class="row g-3 d-none">
										<div class="col-md-6">
											<label for="new_admin_password" class="form-label">{{ trans('new-admin-password') }}</label>
											<input type="password" name="new_admin_password" id="new_admin_password" class="form-control" autocomplete="new-password" placeholder="••••••••"/>
										</div>
										<div class="col-md-6">
											<label for="new_admin_password2" class="form-label">{{ trans('new-admin-password-confirm') }}</label>
											<input type="password" name="new_admin_password2" id="new_admin_password2" class="form-control" autocomplete="new-password" placeholder="••••••••"/>
										</div>
										<div class="col-12">
											<div class="form-check">
												<input class="form-check-input" type="checkbox" name="disable_2fa" id="disable_2fa" value="1"/>
												<label class="form-check-label" for="disable_2fa">{{ trans('restore-admin-disable-2fa') }}</label>
											</div>
										</div>
									</div>
									<div id="admin_create_fields" class="row g-3 d-none">
										<div class="col-md-4">
											<label for="new_admin_nick" class="form-label">{{ trans('nick') }}</label>
											<input type="text" name="new_admin_nick" id="new_admin_nick" class="form-control" autocomplete="off" placeholder="admin2"/>
										</div>
										<div class="col-md-4">
											<label for="new_admin_create_password" class="form-label">{{ trans('password') }}</label>
											<input type="password" name="new_admin_create_password" id="new_admin_create_password" class="form-control" autocomplete="new-password" placeholder="••••••••"/>
										</div>
										<div class="col-md-4">
											<label for="new_admin_create_password2" class="form-label">{{ trans('new-admin-password-confirm') }}</label>
											<input type="password" name="new_admin_create_password2" id="new_admin_create_password2" class="form-control" autocomplete="new-password" placeholder="••••••••"/>
										</div>
									</div>
								</div>
								<div class="card-footer p-2">
									<button type="submit" class="btn btn-warning btn-spin-action">
										<i class="fa-solid fa-rotate-left me-2"></i>
										{{ trans('restore') }}
									</button>
								</div>
							</div>
						</form>

						<form action="{{ fsc.url() }}" id="f_restore_files" method="post" enctype="multipart/form-data">
							{{ formToken() }}
							<input type="hidden" name="action" value="restore-files"/>
							<input type="hidden" name="active_tab" value="restore"/>
							<div class="card shadow mb-4">
								<div class="card-body text-white bg-secondary">
									<h3 class="h5 mb-0">
										<i class="fa-solid fa-upload me-2"></i>
										{{ trans('restore-files') }}
									</h3>
								</div>
								<div class="card-body">
									<p>{{ trans('restore-files-p') }}</p>
									<div class="mb-3">
										<label for="zip_file" class="form-label">{{ trans('files') }}</label>
										<input type="file" name="zip_file" id="zip_file" accept=".zip" class="form-control" required/>
									</div>
									<p class="card-text text-muted">
										{{ trans('help-server-accepts-filesize', {'%size%': fsc.getMaxFileUpload()}) }}
									</p>
								</div>
								<div class="card-footer p-2">
									<button type="submit" class="btn btn-warning btn-spin-action">
										<i class="fa-solid fa-rotate-left me-2"></i>
										{{ trans('restore') }}
									</button>
								</div>
							</div>
						</form>
					</div>
					{% set tabClass = fsc.active_tab == 'settings' ? 'tab-pane fade show active' : 'tab-pane fade' %}
					<div class="{{ tabClass }}" id="settings" role="tabpanel" aria-labelledby="settings-tab">
						<form action="{{ fsc.url() }}" method="get">
							<input type="hidden" name="action" value="switch-db-charset"/>
							<input type="hidden" name="multireqtoken" value="{{ formToken(false) }}"/>
							<input type="hidden" name="active_tab" value="settings"/>
							<div class="card shadow mb-4">
								<div class="card-body">
									<h3 class="h4">
										<i class="fa-solid fa-database me-2"></i>
										{{ trans('switch-db-charset') }}
									</h3>
									<p class="card-text">
										{{ trans('switch-db-charset-p') }}
									</p>
									<div class="mb-3">
										<div class="form-check">
											<input class="form-check-input" type="radio" name="charset" id="charset_utf8" value="utf8" {% if fsc.current_charset == 'utf8' %} checked {% endif %}>
											<label class="form-check-label" for="charset_utf8">
												<strong>UTF-8</strong>
												{% if fsc.current_charset == 'utf8' %}
													<span class="badge bg-success ms-2">{{ trans('active') }}</span>
												{% endif %}
											</label>
										</div>
										<div class="form-check">
											<input class="form-check-input" type="radio" name="charset" id="charset_utf8mb4" value="utf8mb4" {% if fsc.current_charset == 'utf8mb4' %} checked {% endif %}>
											<label class="form-check-label" for="charset_utf8mb4">
												<strong>UTF-8 MB4</strong>
												{% if fsc.current_charset == 'utf8mb4' %}
													<span class="badge bg-success ms-2">{{ trans('active') }}</span>
												{% endif %}
											</label>
										</div>
									</div>
								</div>
								<div class="card-footer p-2">
									<button type="submit" class="btn btn-warning btn-spin-action">
										<i class="fa-solid fa-save me-2"></i>
										{{ trans('save') }}
									</button>
								</div>
							</div>
						</form>

						<div class="card shadow mb-4">
							<div class="card-body">
								<h3 class="h4">
									<i class="fa-solid fa-clock me-2"></i>
									{{ trans('automatic-backup') }}
								</h3>
								<p class="card-text">
									{{ trans('automatic-backup-info') }}
								</p>
								<div class="row">
									<div class="col-md-6">
										<dl class="row mb-0">
											<dt class="col-sm-5">{{ trans('frequency') }}:</dt>
											<dd class="col-sm-7">
												{% if fsc.cron_frequency == '1 day' %}
													{{ trans('daily') }}
												{% elseif fsc.cron_frequency == '1 week' %}
													{{ trans('weekly') }}
												{% elseif fsc.cron_frequency == '1 month' %}
													{{ trans('monthly') }}
												{% else %}
													{{ fsc.cron_frequency }}
												{% endif %}
											</dd>
											{% if fsc.cron_frequency == '1 week' %}
												<dt class="col-sm-5">{{ trans('day') }}:</dt>
												<dd class="col-sm-7">
													{% set days = ['', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'] %}
													{{ trans(days[fsc.cron_weekly_day]) }}
												</dd>
											{% elseif fsc.cron_frequency == '1 month' %}
												<dt class="col-sm-5">{{ trans('day') }}:</dt>
												<dd class="col-sm-7">{{ fsc.cron_monthly_day }}</dd>
											{% endif %}
											<dt class="col-sm-5">{{ trans('hour') }}:</dt>
											<dd class="col-sm-7">{{ fsc.cron_hour }}:00</dd>
										</dl>
									</div>
								</div>
							</div>
							<div class="card-footer p-2">
								<a href="EditSettings?&activetab=SettingsBackup" class="btn btn-primary">
									<i class="fa-solid fa-cog me-2"></i>
									{{ trans('control-panel') }}
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<form action="{{ fsc.url() }}" id="f_delete_backup" method="post">
		{{ formToken() }}
		<input type="hidden" name="action" value="delete-backup"/>
		<input type="hidden" name="db_file">
		<input type="hidden" name="zip_file">
	</form>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		function toggleAdminFields() {
			let action = $('input[name="admin_action"]:checked').val();
			$('#admin_update_fields').toggleClass('d-none', action !== 'update');
			$('#admin_create_fields').toggleClass('d-none', action !== 'create');
		}

		function createBackupAction(action) {
			animateSpinner('add');

			let form = $('#f_download');
			form.find('input[name="action"]').val(action);
			form.find('input[name="multireqtoken"]').val('{{ formToken(false) }}');
			form.submit();
		}

		function deleteBackupAction(db_file, zip_file) {
			let form = $('#f_delete_backup');
			form.find('input[name="db_file"]').val(db_file);
			form.find('input[name="zip_file"]').val(zip_file);
			form.submit();
		}

		function downloadBackupAction(action, file_name = '') {
			let form = $('#f_download');
			form.find('input[name="action"]').val(action);
			form.find('input[name="file_name"]').val(file_name);
			form.submit();
		}

		$(document).ready(function () {
			$('#f_restore_db').on('submit', function (e) {
			animateSpinner('add');
			let fileInput = $(this).find('input[type=file]');
			let fileSize = fileInput[0].files[0].size; // tamaño del archivo en bytes

			if (fileSize > {{ fsc.getMaxFileUpload() }} * 1024 * 1024) { // MB
				e.preventDefault();
				alert('{{ trans('backup-file-too-big', {'%size%': fsc.getMaxFileUpload()}) }}');
				animateSpinner('remove');
			}
		});

		$('#f_restore_files').on('submit', function (e) {
			animateSpinner('add');
			let fileInput = $(this).find('input[type=file]');
			let fileSize = fileInput[0].files[0].size; // tamaño del archivo en bytes

			if (fileSize > {{ fsc.getMaxFileUpload() }} * 1024 * 1024) { // MB
				e.preventDefault();
				alert('{{ trans('backup-file-too-big', {'%size%': fsc.getMaxFileUpload()}) }}');
				animateSpinner('remove');
			}
		});
	});
	</script>
{% endblock %}
